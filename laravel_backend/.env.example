APP_NAME="La Bottega"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://localhost:8005
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=florenceegi
DB_USERNAME=
DB_PASSWORD=
DB_SEARCH_PATH=bottega,core,public

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.florenceegi.com
SESSION_CONNECTION=session

CACHE_STORE=redis
CACHE_PREFIX=bottega

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=bottega:

SANCTUM_STATEFUL_DOMAINS=la-bottega.florenceegi.com,art.florenceegi.com,hub.florenceegi.com,localhost:8005

QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=ses
MAIL_FROM_ADDRESS="bottega@florenceegi.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1

EGI_API_URL=http://localhost:8000/api
EGI_API_TOKEN=

BOTTEGA_PYTHON_URL=http://localhost:8002

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5175
